# =============================================================================
# Travel Planner - Environment Variables
# Copy this file to `.env` for local development, or set these as environment
# variables in the TrueNAS SCALE Custom App / docker-compose.
# =============================================================================

# PostgreSQL connection string.
# - Local dev:  postgresql://postgres:postgres@localhost:5432/travel_planner?schema=public
# - TrueNAS:    point this to YOUR existing PostgreSQL instance on TrueNAS.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_planner?schema=public"

# OpenAI API key used by the AI Card Generator (gpt-4o-mini).
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Port the Next.js standalone server listens on inside the container.
# Mapped to the host as 30001 in docker-compose.yml.
PORT=30001

# Optional: override the OpenAI model (defaults to gpt-4o-mini).
OPENAI_MODEL="gpt-4o-mini"
